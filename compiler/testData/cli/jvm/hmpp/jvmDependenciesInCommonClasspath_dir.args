$TESTDATA_DIR$/src/jvmDependency.kt
-d
$TEMP_DIR$/dependency/
---
$TESTDATA_DIR$/src/jvmDependencyConsumer_common.kt
$TESTDATA_DIR$/src/jvmDependencyConsumer_platform.kt
-Xmulti-platform
-Xseparate-kmp-compilation
-Xfragments=common
-Xfragments=platform
-Xfragment-sources=common\:$TESTDATA_DIR$/src/jvmDependencyConsumer_common.kt
-Xfragment-sources=platform\:$TESTDATA_DIR$/src/jvmDependencyConsumer_platform.kt
-Xfragment-refines=platform\:common
-Xfragment-dependency=common\:$TEMP_DIR$/dependency/
-cp
$TEMP_DIR$/dependency/
-d
$TEMP_DIR$/out/
